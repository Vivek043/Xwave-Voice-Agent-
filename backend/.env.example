# Groq (STT + LLM fallback) — https://console.groq.com
GROQ_API_KEY=gsk_your_key_here

# HuggingFace (Sentiment) — https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here
HF_SENTIMENT_MODEL=distilbert/distilbert-base-uncased-finetuned-sst2-english

# LangSmith (Tracing) — https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_your_key_here
LANGCHAIN_PROJECT=voice-agent

# Ollama (local — no key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# App settings
SENTIMENT_ESCALATION_THRESHOLD=-0.5
ESCALATION_TURN_COUNT=3
PORT=8000
